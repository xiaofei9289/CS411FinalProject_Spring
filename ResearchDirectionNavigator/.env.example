# this is a template for .env — copy this file to .env and fill in your own
# credentials. the real .env file is gitignored and must never be committed.

# ---- MySQL ----
# the default host for MySQL is localhost; if you changed it, change here too
MYSQL_HOST=127.0.0.1
# the default MySQL port is 3306; if you changed it, change here too
MYSQL_PORT=3306
# the default MySQL user is root; if you changed it, change here too
MYSQL_USER=root
# the password for MySQL — use your own secret only in .env (never commit real passwords)
MYSQL_PASSWORD=your_mysql_password
# the database name
MYSQL_DATABASE=academicworld

# ---- MongoDB ----
# default install has no auth, so the URI alone is enough
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DATABASE=academicworld

# ---- Neo4j ----
# required: utils/neo4j.py refuses to start if NEO4J_PASSWORD is empty
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ---- OpenAlex (external API, widget 10) ----
# optional: OpenAlex polite pool (recommended) — your email for API fair use
# OPENALEX_MAILTO=you@example.com
